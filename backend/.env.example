# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Database
# Leave MONGODB_URI empty to spin up an in-memory MongoDB automatically (auto-seeded
# with demo data on first boot — great for local dev/demo).
# Set a real connection string for persistence, e.g. mongodb://127.0.0.1:27017/nagarfix
MONGODB_URI=

# Force (re)seeding demo data on startup even with a persistent DB
SEED_ON_START=false
